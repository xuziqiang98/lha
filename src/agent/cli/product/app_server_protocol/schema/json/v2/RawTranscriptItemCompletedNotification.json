        }
      ]
    },
    "ToolResultContentItem": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "text",
            "type"
          ],
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "input_text"
              ],
              "title": "InputTextToolResultContentItemType"
            }
          },
          "title": "InputTextToolResultContentItem"
        },
        {
          "type": "object",
          "required": [
            "image_url",
            "type"
          ],
          "properties": {
            "image_url": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "input_image"
              ],
              "title": "InputImageToolResultContentItemType"
            }
          },
          "title": "InputImageToolResultContentItem"
        }
      ]
    },
    "ToolResultPayload": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "content",
            "type"
          ],
          "properties": {
            "content": {
              "type": "string"
            },
            "content_items": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "$ref": "#/definitions/ToolResultContentItem"
              }
            },
            "success": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "structured"
              ],
              "title": "StructuredToolResultPayloadType"
            }
          },
          "title": "StructuredToolResultPayload"
        },
        {
          "type": "object",
          "required": [
            "output",
            "type"
          ],
          "properties": {
            "output": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "text"
              ],
              "title": "TextToolResultPayloadType"
            }
          },
          "title": "TextToolResultPayload"
        }
      ]
    },
    "TranscriptItem": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "content",
            "role",
            "type"
          ],
          "properties": {
            "content": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ContentItem"
              }
            },
            "end_turn": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "id": {
              "type": [
                "string",
                "null"
              ]
            },
            "role": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "message"
              ],
              "title": "MessageTranscriptItemType"
            }
          },
          "title": "MessageTranscriptItem"
        },
        {
          "type": "object",
          "required": [
            "id",
            "summary",
            "type"
          ],
          "properties": {
            "content": {
              "default": null,
              "type": [
                "array",
                "null"
              ],
              "items": {
                "$ref": "#/definitions/ReasoningItemContent"
              }
            },
            "encrypted_content": {
              "type": [
                "string",
                "null"
              ]
            },
            "id": {
              "type": "string"
            },
            "summary": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ReasoningItemReasoningSummary"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "reasoning"
              ],
              "title": "ReasoningTranscriptItemType"
            }
          },
          "title": "ReasoningTranscriptItem"
        },
        {
          "type": "object",
          "required": [
            "activity_type",
            "payload",
            "type"
          ],
          "properties": {
            "activity_type": {
              "type": "string"
            },
            "id": {
              "type": [
                "string",
                "null"
              ]
            },
            "payload": true,
            "status": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "hosted_activity"
              ],
              "title": "HostedActivityTranscriptItemType"
            }
          },
          "title": "HostedActivityTranscriptItem"
        },
        {
          "type": "object",
          "required": [
            "call_id",
            "payload",
            "tool_name",
            "type"
          ],
          "properties": {
            "call_id": {
              "type": "string"
            },
            "id": {
              "type": [
                "string",
                "null"
              ]
            },
            "payload": {
              "$ref": "#/definitions/ToolCallPayload"
            },
            "tool_name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "tool_call"
              ],
              "title": "ToolCallTranscriptItemType"
            }
          },
          "title": "ToolCallTranscriptItem"
        },
        {
          "type": "object",
          "required": [
            "call_id",
            "payload",
            "tool_name",
            "type"
          ],
          "properties": {
            "call_id": {
              "type": "string"
            },
            "payload": {
              "$ref": "#/definitions/ToolResultPayload"
            },
            "tool_name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "tool_result"
              ],
              "title": "ToolResultTranscriptItemType"
            }
          },
          "title": "ToolResultTranscriptItem"
        },
        {
          "type": "object",
          "required": [
            "raw",
            "type"
          ],
          "properties": {
            "raw": true,
            "type": {
              "type": "string",
              "enum": [
                "unknown"
              ],
              "title": "UnknownTranscriptItemType"
            }
          },
          "title": "UnknownTranscriptItem"
        }
      ]
    }
  }
}