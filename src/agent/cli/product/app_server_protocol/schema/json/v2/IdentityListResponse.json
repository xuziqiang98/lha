{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IdentityListResponse",
  "description": "EXPERIMENTAL - identity presets response.",
  "type": "object",
  "required": [
    "data"
  ],
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/IdentityMask"
      }
    }
  },
  "definitions": {
    "IdentityCapabilities": {
      "description": "Capabilities associated with an identity.",
      "type": "object",
      "required": [
        "write_tools"
      ],
      "properties": {
        "write_tools": {
          "description": "Whether this identity is intended to have write-capable tools. This is currently metadata only; tool exposure is not filtered from this field yet.",
          "type": "boolean"
        }
      }
    },
    "IdentityKind": {
      "description": "Built-in LHA identity kind.",
      "type": "string",
      "enum": [
        "nobody",
        "planner",
        "programmer",
        "explorer",
        "reviewer"
      ]
    },
    "IdentityMask": {
      "description": "A mask for identity settings, allowing partial updates. All fields except `name` are optional, enabling selective updates.",
      "type": "object",
      "required": [
        "capabilities",
        "name"
      ],
      "properties": {
        "capabilities": {
          "$ref": "#/definitions/IdentityCapabilities"
        },
        "developer_instructions": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "anyOf": [
            {
              "$ref": "#/definitions/IdentityKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "reasoning_effort": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "$ref": "#/definitions/ReasoningEffort"
                },
                {
                  "type": "null"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "ReasoningEffort": {
      "type": "string",
      "enum": [
        "none",
        "minimal",
        "low",
        "medium",
        "high",
        "xhigh"
      ]
    }
  }
}