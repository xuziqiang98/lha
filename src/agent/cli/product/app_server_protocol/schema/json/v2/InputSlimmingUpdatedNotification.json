{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InputSlimmingUpdatedNotification",
  "type": "object",
  "required": [
    "inputSlimming",
    "threadId",
    "turnId"
  ],
  "properties": {
    "inputSlimming": {
      "$ref": "#/definitions/InputSlimmingStats"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "definitions": {
    "InputSlimmingScope": {
      "type": "string",
      "enum": [
        "historicalToolOutputs",
        "liveZoneToolOutputs"
      ]
    },
    "InputSlimmingStats": {
      "type": "object",
      "required": [
        "last",
        "scope",
        "total"
      ],
      "properties": {
        "last": {
          "$ref": "#/definitions/InputSlimmingTokenStats"
        },
        "scope": {
          "$ref": "#/definitions/InputSlimmingScope"
        },
        "total": {
          "$ref": "#/definitions/InputSlimmingTokenStats"
        }
      }
    },
    "InputSlimmingTokenStats": {
      "type": "object",
      "required": [
        "replacements",
        "tokensAfter",
        "tokensBefore",
        "tokensSaved"
      ],
      "properties": {
        "replacements": {
          "type": "integer",
          "format": "int64"
        },
        "savedUsdMicros": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int64"
        },
        "tokensAfter": {
          "type": "integer",
          "format": "int64"
        },
        "tokensBefore": {
          "type": "integer",
          "format": "int64"
        },
        "tokensSaved": {
          "type": "integer",
          "format": "int64"
        }
      }
    }
  }
}