            },
            "type": {
              "type": "string",
              "enum": [
                "message"
              ],
              "title": "MessageTranscriptItemType"
            }
          },
          "title": "MessageTranscriptItem"
        },
        {
          "type": "object",
          "required": [
            "id",
            "summary",
            "type"
          ],
          "properties": {
            "content": {
              "default": null,
              "type": [
                "array",
                "null"
              ],
              "items": {
                "$ref": "#/definitions/ReasoningItemContent"
              }
            },
            "encrypted_content": {
              "type": [
                "string",
                "null"
              ]
            },
            "id": {
              "type": "string"
            },
            "summary": {
