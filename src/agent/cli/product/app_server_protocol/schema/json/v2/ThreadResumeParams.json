              ],
              "items": {
                "$ref": "#/definitions/ToolResultContentItem"
              }
            },
            "success": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "enum": [
                "structured"
              ],
              "title": "StructuredToolResultPayloadType"
            }
          },
          "title": "StructuredToolResultPayload"
        },
        {
          "type": "object",
          "required": [
            "output",
            "type"
          ],
          "properties": {
            "output": {
              "type": "string"
            },
            "type": {
              "type": "string",
